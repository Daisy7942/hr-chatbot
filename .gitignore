# 환경변수 (API 키 등 민감 정보)
.env
**/.env

# Python 가상환경
venv/
.venv/

# 원본 인사 데이터 (주민등록번호 등 민감정보 포함 → git에 올리지 않음)
data/dataset/*.csv
*.csv
*.jsonl

# 전처리 에러 로그 (실행할 때마다 자동 생성)
data/error.log

# OpenSearch 설치 폴더 (대용량)
opensearch-3.3.2/
opensearch-dashboards-3.3.0/

# 모델 파일 (대용량)
models/
*.gguf

# Python 캐시
__pycache__/
*.pyc
*.pyo

# Jupyter 노트북
*.ipynb
.ipynb_checkpoints/

# 문서 파일
*.pdf
*.docx

# 운영체제
.DS_Store
Thumbs.db
